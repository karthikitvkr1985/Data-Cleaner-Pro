# DataClean — Environment Variables
# Copy to .env and fill in values before running

# --- Required for AI features ---
# Anthropic API key for NL command parsing (Claude Haiku)
# Without this, NL commands fall back to a simpler rule-based parser
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# --- Optional backend configuration ---
SESSION_TTL_MINUTES=60       # How long to keep sessions in memory (default: 60)
MAX_FILE_SIZE_MB=100         # Max upload file size in MB (default: 100)
FUZZY_DEDUP_THRESHOLD=90    # Fuzzy match threshold 0-100 (default: 90)
CORS_ORIGINS=*               # Comma-separated CORS origins (default: * = all)

# --- Frontend configuration ---
# URL prefix the frontend uses to reach the API
# In Replit: leave blank (proxy handles routing)
# On Render/Vercel: set to your backend URL e.g. https://api.myapp.com
VITE_API_BASE_URL=
